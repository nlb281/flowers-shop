<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:flowersShop.ViewModels"
        mc:Ignorable="d"
        Width="450"
        Height="350"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        x:Class="flowersShop.Views.ChangeOrderStatusWindow"
        x:DataType="viewModels:ChangeOrderStatusWindowViewModel"
        Title="Изменение статуса">

    <Grid Margin="20"
          RowDefinitions="Auto,Auto,Auto,*"
          RowSpacing="20">
        
        <TextBlock
            Grid.Row="0"
            Text="Изменение статуса"
            FontSize="26"
            FontWeight="Bold"/>
        
        <Border Grid.Row="1"
                Padding="15"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                CornerRadius="10">

            <Grid RowDefinitions="Auto,Auto,Auto"
                  RowSpacing="10">

                <TextBlock
                    Grid.Row="0"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Text="{Binding Order.Id, StringFormat='Заказ #{0}'}"/>

                <TextBlock
                    Grid.Row="1"
                    FontSize="15"
                    Text="{Binding Order.Client.Fio, StringFormat='Клиент: {0}'}"/>

                <TextBlock
                    Grid.Row="2"
                    FontSize="15"
                    Text="{Binding Order.Status, StringFormat='Текущий статус: {0}'}"/>

            </Grid>

        </Border>
        
        <StackPanel Grid.Row="2"
                    Spacing="10">

            <TextBlock
                Text="Новый статус"
                FontSize="16"
                FontWeight="SemiBold"/>

            <ComboBox
                ItemsSource="{Binding Statuses}"
                SelectedItem="{Binding SelectedStatus}"/>

        </StackPanel>
        
        <Grid Grid.Row="3"
              ColumnDefinitions="*,*"
              ColumnSpacing="15"
              VerticalAlignment="Bottom">

            <Button
                Grid.Column="1"
                Height="45"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                FontSize="15"
                FontWeight="SemiBold"
                Foreground="#272727"
                Background="Transparent"
                BorderBrush="#272727"
                BorderThickness="1"
                Content="Назад"
                Command="{Binding GoBack}"/>
            
            <Button
                Grid.Column="0"
                Height="45"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                FontSize="15"
                FontWeight="SemiBold"
                Foreground="#fff"
                Background="#272727"
                Content="Сохранить"
                Command="{Binding SaveStatus}"/>

        </Grid>

    </Grid>

</Window>