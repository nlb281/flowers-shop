<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:flowersShop"
        xmlns:viewModels="clr-namespace:flowersShop.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="flowersShop.Views.CreateOrderWindow"
        x:DataType="viewModels:CreateOrderWindowViewModel"
        Title="Оформление заказа"
        Width="1440" 
        Height="768"
        WindowStartupLocation="CenterScreen">

    <Grid ColumnDefinitions="3*,1.1*"
          Margin="15"
          ColumnSpacing="20">
        
        <Border Grid.Column="0"
                Padding="20"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                CornerRadius="10">

            <Grid RowDefinitions="Auto,Auto,Auto,Auto,*"
                  RowSpacing="15">

                <TextBlock
                    Grid.Row="0"
                    Text="Оформление заказа"
                    FontSize="30"
                    FontWeight="Bold"/>
                
                <StackPanel Grid.Row="1"
                            Spacing="10">

                    <TextBlock
                        Text="Клиент"
                        FontSize="18"
                        FontWeight="SemiBold"/>

                    <ComboBox
                        ItemsSource="{Binding Clients}"
                        SelectedItem="{Binding SelectedClient}"
                        HorizontalAlignment="Stretch">

                        <ComboBox.ItemTemplate>

                            <DataTemplate>

                                <TextBlock Text="{Binding Fio}"/>

                            </DataTemplate>

                        </ComboBox.ItemTemplate>

                    </ComboBox>

                    <Button
                        HorizontalAlignment="Left"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="Black"
                        Click="GoToAddNewClientWindow_OnClick">

                        <TextBlock
                            Text="Добавить нового клиента"
                            TextDecorations="Underline"
                            FontSize="15"
                            FontWeight="SemiBold"/>

                    </Button>

                </StackPanel>
                
                <StackPanel Grid.Row="2"
                            Spacing="10">

                    <TextBlock
                        Text="Адрес доставки"
                        FontSize="18"
                        FontWeight="SemiBold"/>

                    <TextBox
                        Text="{Binding Address}"
                        Watermark="Введите адрес доставки"/>

                </StackPanel>
                
                <StackPanel Grid.Row="3"
                            Spacing="10">

                    <TextBlock
                        Text="Дата доставки"
                        FontSize="18"
                        FontWeight="SemiBold"/>

                    <DatePicker  SelectedDate="{Binding DeliveryDate}"/>

                    <TextBlock
                        Text="Доставка доступна начиная с завтрашнего дня"
                        Foreground="Gray"
                        FontSize="13"/>

                </StackPanel>
                
                <StackPanel Grid.Row="4"
                            Spacing="10">

                    <TextBlock
                        Text="Свободный курьер"
                        FontSize="18"
                        FontWeight="SemiBold"/>

                    <ComboBox
                        ItemsSource="{Binding FreeCouriers}"
                        SelectedItem="{Binding SelectedCourier}"
                        HorizontalAlignment="Stretch">

                        <ComboBox.ItemTemplate>

                            <DataTemplate>

                                <TextBlock Text="{Binding Fio}"/>

                            </DataTemplate>

                        </ComboBox.ItemTemplate>

                    </ComboBox>

                </StackPanel>

            </Grid>

        </Border>
        
        <Border Grid.Column="1"
                Padding="15"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                CornerRadius="10">

            <Grid RowDefinitions="Auto,*,Auto,Auto"
                  RowSpacing="15">

                <TextBlock
                    Grid.Row="0"
                    Text="Ваш заказ"
                    FontSize="28"
                    FontWeight="Bold"/>
                
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding CartItems}"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">

                    <ListBox.ItemTemplate>

                        <DataTemplate>

                            <Border
                                Width="270"
                                Margin="10"
                                Padding="10"
                                BorderBrush="#D0D0D0"
                                BorderThickness="1"
                                CornerRadius="10">

                                <StackPanel Spacing="8">

                                    <Image
                                        Height="250"
                                        Width="250"
                                        Stretch="UniformToFill"
                                        Source="{Binding ImageBitmap}"/>

                                    <TextBlock
                                        Text="{Binding Name}"
                                        FontSize="16"
                                        FontWeight="Bold"
                                        TextWrapping="Wrap"/>

                                    <TextBlock
                                        Text="{Binding Quantity, StringFormat='Количество: {0}'}"/>

                                    <TextBlock
                                        Text="{Binding TotalPrice, StringFormat='Сумма: {0:F2} ₽'}"
                                        FontWeight="Bold"/>

                                </StackPanel>

                            </Border>

                        </DataTemplate>

                    </ListBox.ItemTemplate>

                </ListBox>

                <TextBlock
                    Grid.Row="2"
                    Text="{Binding TotalPrice}"
                    FontSize="24"
                    FontWeight="Bold"/>

                <Grid Grid.Row="3"
                      RowDefinitions="*,*"
                      RowSpacing="10">

                    <Button
                        Grid.Row="0"
                        Height="45"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="#fff"
                        Background="#272727"
                        Content="Подтвердить заказ"
                        Click="CreateOrder_OnClick"/>

                    <Button
                        Grid.Row="1"
                        Height="45"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="Black"
                        Click="GoToMainWindow_OnClick">

                        <TextBlock
                            Text="Вернуться назад"
                            TextDecorations="Underline"
                            FontSize="15"
                            FontWeight="SemiBold"
                            />

                    </Button>

                </Grid>

            </Grid>

        </Border>

    </Grid>

</Window>

