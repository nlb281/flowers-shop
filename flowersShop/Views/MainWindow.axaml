<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:flowersShop.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1400"
        d:DesignHeight="800"
        x:Class="flowersShop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Flowers Shop">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid ColumnDefinitions="3*,1.1*"
          Margin="15"
          ColumnSpacing="20">

        <Grid Grid.Column="0"
              RowDefinitions="Auto,Auto,*"
              RowSpacing="15">
            
            <TextBlock
                Grid.Row="0"
                Text="Каталог букетов"
                FontSize="30"
                FontWeight="Bold"/>
            
            <CheckBox
                Grid.Row="1"
                Content="Только в наличии"
                IsChecked="{Binding OnlyAvailable}"/>
            
            <ListBox
                Grid.Row="2"
                ItemsSource="{Binding Flowers}"
                BorderThickness="0"
                Background="Transparent"
                ScrollViewer.VerticalScrollBarVisibility="Auto">
                
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                
                <ListBox.Styles>

                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>

                    <Style Selector="ListBoxItem:selected">
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>

                    <Style Selector="ListBoxItem:pointerover">
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>

                </ListBox.Styles>
                
                <ListBox.ItemTemplate>

                    <DataTemplate>

                        <Border
                            Width="270"
                            Margin="10"
                            Padding="10"
                            BorderBrush="#D0D0D0"
                            BorderThickness="1"
                            CornerRadius="10">

                            <StackPanel Spacing="10">

                                <Image
                                    Height="250"
                                    Width="250"
                                    Stretch="UniformToFill"
                                    Source="{Binding ImageBitmap}"/>

                                <TextBlock
                                    Text="{Binding Name}"
                                    FontSize="20"
                                    FontWeight="Bold"
                                    TextWrapping="Wrap"/>

                                <TextBlock
                                    Text="{Binding Description}"
                                    TextWrapping="Wrap"
                                    MaxHeight="60"/>

                                <TextBlock
                                    Text="{Binding Price, StringFormat='Цена: {0:F2} ₽'}"
                                    FontWeight="Bold"
                                    FontSize="16"/>

                                <TextBlock
                                    Text="{Binding Quantity, StringFormat='Остаток: {0}'}"/>

                                <Button
                                    Content="{Binding AddButtonText}"
                                    IsEnabled="{Binding CanAddToCart}"
                                    Height="40"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    FontSize="15"
                                    FontWeight="600"
                                    Foreground="#fff"
                                    Background="#272727"
                                    Click="AddToCart_OnClick"/>

                            </StackPanel>

                        </Border>

                    </DataTemplate>

                </ListBox.ItemTemplate>

            </ListBox>

        </Grid>

        <Border Grid.Column="1"
                Padding="15"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                CornerRadius="10">

            <Grid RowDefinitions="Auto,*,Auto,Auto,Auto"
                  RowSpacing="15">
                
                <TextBlock
                    Grid.Row="0"
                    Text="Корзина"
                    FontSize="28"
                    FontWeight="Bold"/>
                
                <ListBox
                    Grid.Row="1"
                    ItemsSource="{Binding CartItems}"
                    BorderThickness="0"
                    Background="Transparent"
                    ScrollViewer.VerticalScrollBarVisibility="Auto">
                    
                    <ListBox.ItemTemplate>

                        <DataTemplate>

                            <Border
                                Width="270"
                                Margin="10"
                                Padding="10"
                                BorderBrush="#D0D0D0"
                                BorderThickness="1"
                                CornerRadius="10">

                                <StackPanel Spacing="8">
                                    
                                    <Image
                                        Height="250"
                                        Width="250"
                                        Stretch="UniformToFill"
                                        Source="{Binding ImageBitmap}"/>
                                    
                                    <TextBlock
                                        Text="{Binding Name}"
                                        FontWeight="Bold"
                                        FontSize="16"
                                        TextWrapping="Wrap"/>
                                    
                                    <TextBlock
                                        Text="{Binding Quantity, StringFormat='Количество: {0}'}"/>
                                    
                                    <TextBlock
                                        Text="{Binding TotalPrice, StringFormat='Сумма: {0:F2} ₽'}"
                                        FontWeight="Bold"/>
                                    <StackPanel Orientation="Horizontal" Spacing="3">
                                        <Button
                                            Content="-"
                                            Height="40"
                                            Width="40"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            FontSize="15"
                                            FontWeight="600"
                                            Foreground="#fff"
                                            Background="#272727"
                                            Click="RemoveOneFromCart_OnClick"/>
                                        
                                        <Button
                                            Height="40"
                                            Width="40"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            FontSize="15"
                                            FontWeight="600"
                                            Foreground="#fff"
                                            Background="#272727"
                                            Click="RemoveFromCart_OnClick">
                                            
                                            <Image
                                                Width="18"
                                                Height="18"
                                                Source="avares://flowersShop/Assets/icons/trash.png"/>
                                            
                                        </Button>
                                        
                                        <Button
                                            Content="+"
                                            Height="40"
                                            Width="40"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            FontSize="15"
                                            FontWeight="600"
                                            Foreground="#fff"
                                            Background="#272727"
                                            Click="AddOneToCart_OnClick"/>
                                    </StackPanel>
                                    

                                </StackPanel>

                            </Border>

                        </DataTemplate>

                    </ListBox.ItemTemplate>

                </ListBox>
                
                <TextBlock
                    Grid.Row="2"
                    Text="{Binding TotalPrice, StringFormat='Итого: {0:F2} ₽'}"
                    FontSize="22"
                    FontWeight="Bold"/>
                
                <Grid Grid.Row="3"
                      RowDefinitions="*,*"
                      RowSpacing="10">

                    <Button
                        Grid.Row="0"
                        Height="45"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="#fff"
                        Background="#272727"
                        Content="Оформить заказ"/>

                    <Button
                        Grid.Row="1"
                        Height="45"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="Black">

                        <TextBlock
                            Text="Все заказы"
                            TextDecorations="Underline"
                            FontSize="15"
                            FontWeight="SemiBold"/>

                    </Button>

                </Grid>
                
            </Grid>

        </Border>

    </Grid>

</Window>